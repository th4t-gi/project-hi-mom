---
import ThemeToggle from './ThemeToggle.tsx';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about`, label: 'About' },
  { href: '#', label: 'CV' },
  { href: `${base}/projects`, label: 'Projects' },
  { href: `${base}/competencies`, label: 'Competencies' },
];
---

<nav class="flex justify-end items-center gap-6 px-8 py-4">
  <!-- <a href="/" 
    class="font-bold tracking-wide no-underline transition-colors text-text-muted hover:text-text">
  Judd Brau</a>

  <div class="flex-1"></div> -->

  {links.map(({ href, label }) => (
    <a 
      href={href}
      class:list={[
        'text-sm font-medium tracking-wide uppercase no-underline transition-colors',
        currentPath === href || currentPath === href + '/' || (href !== '/' && currentPath.startsWith(href))
          ? 'text-accent'
          : 'text-text-muted hover:text-text',
      ]}
    >
      {label}
    </a>
  ))}
  <ThemeToggle client:load />
</nav>
