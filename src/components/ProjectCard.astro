---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="border-b border-border pb-6">
  <div class="flex flex-col md:flex-row gap-6">
    <div class="flex-1">
      <h3 class="text-xl font-semibold text-text mb-2">{project.title}</h3>
      <p class="text-text-muted mb-3">{project.description}</p>
      <div class="flex flex-wrap gap-2">
        {project.technologies.map((tech) => (
          <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-accent/15 text-accent">
            {tech}
          </span>
        ))}
      </div>
    </div>
    {project.image ? (
      <img
        src={project.image}
        alt={`${project.title} screenshot`}
        class="w-full md:w-48 h-32 object-cover rounded-md"
      />
    ) : (
      <div class="w-full md:w-48 h-32 bg-surface rounded-md flex items-center justify-center text-text-muted text-sm">
        Screenshot
      </div>
    )}
  </div>
</article>
